# ─────────────────────────────────────────────────────────────────────────────
# PropSync Server Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env!
# Generate secure secrets with: openssl rand -base64 64
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (include /PropSync as the DB name)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/PropSync?retryWrites=true&w=majority

# ── JWT Authentication ────────────────────────────────────────────────────────
# MUST be a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
# Development:   http://localhost:5173
# Production:    https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ── Email (SendGrid) — Optional ───────────────────────────────────────────────
# Required if you enable email notifications or password-reset emails
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@propsync.app

# ── Realtime (Socket.IO) ──────────────────────────────────────────────────────
# How often (ms) to poll live-user presence (default 30 s)
LIVE_USERS_POLL_MS=30000

# ── File Uploads (Cloudinary) — Optional ─────────────────────────────────────
# Needed if you enable image/document upload features
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
