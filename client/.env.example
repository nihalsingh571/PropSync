# ─────────────────────────────────────────────────────────────────────────────
# PropSync Frontend Environment Variables (Vite)
# All variables must be prefixed with VITE_ to be exposed to the browser.
# Copy this file to .env.local and fill in real values. NEVER commit .env.local!
# ─────────────────────────────────────────────────────────────────────────────

# ── API Base URL ──────────────────────────────────────────────────────────────
# Development (local server):
VITE_API_URL=http://localhost:8000/api
# Production (Render backend — uncomment and set after deploying):
# VITE_API_URL=https://propsync-api.onrender.com/api
